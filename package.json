{
  "name": "prooflayer-sdk",
  "version": "0.1.0",
  "description": "Opt-in behavioral trust scoring SDK for AI agents. Track agent activity, generate multi-dimensional trust scores, and publish on-chain EAS attestations.",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "bin": {
    "prooflayer": "./src/cli.js"
  },
  "files": [
    "dist",
    "src/cli.js",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts --clean",
    "dev": "tsup src/index.ts --format cjs,esm --dts --watch",
    "lint": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "ai-agents",
    "trust-score",
    "x402",
    "attestation",
    "eas",
    "base",
    "prooflayer",
    "agent-reputation",
    "behavioral-scoring"
  ],
  "author": "plagtech",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/plagtech/prooflayer-sdk"
  },
  "dependencies": {
    "ethers": "^6.13.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "tsup": "^8.1.0",
    "typescript": "^5.5.0",
    "vitest": "^1.6.0"
  },
  "peerDependencies": {
    "ethers": "^6.0.0"
  },
  "peerDependenciesMeta": {
    "ethers": {
      "optional": true
    }
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
